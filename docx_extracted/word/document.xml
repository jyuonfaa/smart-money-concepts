val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/><w:u w:val="single"/></w:rPr><w:t>Video 1: Elements To A Trade Setup;</w:t></w:r></w:p><w:p w14:paraId="38C14F3B" w14:textId="357C1CB1" w:rsidR="00B46AD9" w:rsidRDefault="00B46AD9" w:rsidP="00B46AD9"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>This is the first of 8 videos. When we refer to elements of a trade setup, there are really just two primary concerns and they are listed below</w:t></w:r></w:p><w:p w14:paraId="5100B24E" w14:textId="16193133" w:rsidR="00B46AD9" w:rsidRPr="00265F44" w:rsidRDefault="00B46AD9" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="00265F44"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Context or framework surrounding the idea:</w:t></w:r></w:p><w:p w14:paraId="2A353323" w14:textId="7B7D1F1B" w:rsidR="00B46AD9" w:rsidRDefault="00B46AD9" w:rsidP="00B46AD9"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">This is what makes the idea </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>favorable</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> for a trade and not simply what your indicators or support and resistance level says. There should be something that builds a reason to want to trade. We will be learning specific principles and we are going to be dealing with them in</w:t></w:r><w:r w:rsidR="00265F44"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> general terms and what we do in those conditions. These conditions are listed below:</w:t></w:r></w:p><w:p w14:paraId="6D0A6490" w14:textId="3D49918B" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Expansion</w:t></w:r></w:p><w:p w14:paraId="160D8BFE" w14:textId="0D8B7DF8" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Retracement/pullback</w:t></w:r></w:p><w:p w14:paraId="24CE3B4A" w14:textId="2D63BDF5" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Reversal</w:t></w:r></w:p><w:p w14:paraId="1D8FB15D" w14:textId="1186C866" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Consolidation</w:t></w:r></w:p><w:p w14:paraId="4A2A4011" w14:textId="5B2AEDE7" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Each one of these four gives a specific framework and a context to the marketplace that we are going to be trading in. There is going to be either one of the four conditions. </w:t></w:r></w:p><w:p w14:paraId="474BB923" w14:textId="77777777" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="09FA8A80" w14:textId="392E7AB9" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Reference Points In Institutional Order Flow</w:t></w:r></w:p><w:p w14:paraId="37BE0B19" w14:textId="5984E68B" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Orderblocks</w:t></w:r><w:proofErr w:type="spellEnd"/></w:p><w:p w14:paraId="76704B00" w14:textId="24E2B20B" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Fair Value Gaps &amp; Liquidity Voids</w:t></w:r></w:p><w:p w14:paraId="349F2BDA" w14:textId="71CAEAAC" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Liquidity Pools &amp; Stop Runs</w:t></w:r></w:p><w:p w14:paraId="630AE23E" w14:textId="315A4C2E" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Equilibrium</w:t></w:r></w:p><w:p w14:paraId="7E3E7C7C" w14:textId="77777777" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="4F0935F4" w14:textId="1B69A18E" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="3AA85723" w14:textId="462A6F76" w:rsidR="00265F44" w:rsidRPr="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr></w:pPr><w:r w:rsidRPr="00265F44"><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:lastRenderedPageBreak/><w:t>The Interbank Price Delivery Algorithm</w:t></w:r><w:r w:rsidR="005D2F8F"><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:t>(Also called the interbank algo)</w:t></w:r></w:p><w:p w14:paraId="3DC6D291" w14:textId="54EC7F0C" w:rsidR="00265F44" w:rsidRDefault="00265F44" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>It i</w:t></w:r><w:r w:rsidR="005D2F8F"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">s the algorithm that controls market movement. It works with a set of rules just like any computer program. </w:t></w:r></w:p><w:p w14:paraId="3B772DC4" w14:textId="7B274E2B" w:rsidR="002B7882" w:rsidRDefault="002B7882" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="002B7882"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="2DEEB5D8" wp14:editId="49561C2C"><wp:extent cx="5731510" cy="3214370"/><wp:effectExtent l="0" t="0" r="2540" b="5080"/><wp:docPr id="219931678" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="219931678" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId5"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5731510" cy="3214370"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="39B9402B" w14:textId="53E43C7E" w:rsidR="005D2F8F" w:rsidRDefault="005D2F8F" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">There is going to be times where the market goes sideways(same as consolidation). When this happens, the market will be looking to do an expansion. All markets start from a consolidation and move into an expansion(that’s an impulse price swing). After that impulse </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>swing,it</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> either goes to a consolidation again or it goes to a retracement. When a retracement </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>happens,it</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> goes back down into another level of expansion or after </w:t></w:r><w:r w:rsidR="00972167"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">expansion, it can go to a reversal pattern, after the reversal pattern, it will see another retracement then back to potentially consolidation. These four conditions interchange throughout the marketplace. You are only going to get one of these four conditions. You just need to know where the market is at right now, where it is likely to go and where it came from. Throughout the course, you are going to learn a lot about where the market is going next and that’s going to fill in a lot of gaps. </w:t></w:r></w:p><w:p w14:paraId="4E2BA0DC" w14:textId="77777777" w:rsidR="00972167" w:rsidRDefault="00972167" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="40CD6E21" w14:textId="5F7D48D9" w:rsidR="00972167" w:rsidRDefault="00972167" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">The main thing, the consolidation begins with everything. All the moves that take place in the marketplace start with a measure of consolidation. That’s where the market builds orders. The market maker keeps market in a tight range or defined </w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:t>range until there is enough money on both parts of the upper and lower ends of the range is being defined by the consolidation. Whichever one has the highest amount of money to be absorbed, that’s the direction it is going to move in.</w:t></w:r><w:r w:rsidR="009F50F4"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> We don’t always know what that is but we wait for the expansion, when the expansion occurs, that’s when we get the clue as to what the market is most likely going to be doing and wait for a retracement or another consolidation or </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="009F50F4"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>reversal.We</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidR="009F50F4"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> always wait for the first expansion which gives us all the insights that we need to make a decision. Sometimes it may expand so far that we can’t do anything with it that we have to wait for the retracement or the next consolidation. There is nothing wrong with that, it is all </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="009F50F4"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>normal,you</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidR="009F50F4"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> are not going to catch every move. The main thing is understanding these four individual characteristics to a trade setup because price is delivered by one of these four conditions. It can’t be any other way.</w:t></w:r></w:p><w:p w14:paraId="6709DB6C" w14:textId="77777777" w:rsidR="009F50F4" w:rsidRDefault="009F50F4" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="364E6494" w14:textId="77777777" w:rsidR="009F50F4" w:rsidRDefault="009F50F4" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="35F59CBF" w14:textId="458842E1" w:rsidR="009F50F4" w:rsidRDefault="009F50F4" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr></w:pPr><w:r w:rsidRPr="009F50F4"><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:t>What is Expansion?</w:t></w:r></w:p><w:p w14:paraId="4395DE86" w14:textId="26E25C88" w:rsidR="009F50F4" w:rsidRDefault="009F50F4" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Expansion is when price moves quickly from a level of equilibrium. Expansion couples directly with the to</w:t></w:r><w:r w:rsidR="0040359A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>o</w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">l of an order block. </w:t></w:r></w:p><w:p w14:paraId="54051296" w14:textId="6F539A94" w:rsidR="009F50F4" w:rsidRDefault="009F50F4" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">The Importance of Expansion; When price leaves a </w:t></w:r><w:r w:rsidR="0068293F"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">level quickly, this indicates a willingness on the part of the market makers to reveal their intended repricing model. Now what does that mean? Well,  if we are in a consolidation or point of equilibrium, if price wants to move up quickly, that will give us an indication of looking for a bullish </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="0068293F"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>orderblock</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidR="0068293F"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">, we don’t want to chase price, we want to wait for price to come back down into the </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="0068293F"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>orderblock</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidR="0068293F"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">. Where is that going to occur? Well, what do we look for in price? The order block that the market makers leave near or at equilibrium price point. </w:t></w:r></w:p><w:p w14:paraId="5D844DC2" w14:textId="39084048" w:rsidR="002B7882" w:rsidRDefault="002B7882" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="002B7882"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="0C96D59D" wp14:editId="59AF335E"><wp:extent cx="5731510" cy="3245485"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="1373861692" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="1373861692" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId6"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5731510" cy="3245485"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="32293674" w14:textId="2147D4D1" w:rsidR="0068293F" w:rsidRDefault="002B7882" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">As you can see here, there’s a consolidation in the blue shaded area. This is a very clear defined consolidation. It’s got a clear </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>discernable</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> high and low and the equilibrium price point is directly in the middle of the high and the low end of that range. You can simply take the Fibonacci tool , lay the fib on the high and the low in the general consolidation to find that midpoint. The market will eventually move outside of the consolidation</w:t></w:r><w:r w:rsidR="0081417A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>. You can see that impulse move in the yellow-like shaded box. It moves away from the equilibrium price point and all we have to do is go back to the down candle right before that up move. That down candle(black candle) is the bullish order block. When the price comes back down into that and hits it that’s where we would be buying. Obviously you can see it hits that level and expands to the up side.</w:t></w:r></w:p><w:p w14:paraId="07802E05" w14:textId="4C3CC54E" w:rsidR="0068293F" w:rsidRDefault="0068293F" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr></w:pPr><w:r w:rsidRPr="0068293F"><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:t>What is Retracement</w:t></w:r><w:r><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:t>?</w:t></w:r></w:p><w:p w14:paraId="4DC66651" w14:textId="529D1A55" w:rsidR="0068293F" w:rsidRDefault="0068293F" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Retracement is when price moves back inside the recently created price range. </w:t></w:r></w:p><w:p w14:paraId="2C55808D" w14:textId="34078B6F" w:rsidR="00660B99" w:rsidRDefault="00660B99" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">The Importance of Retracement: When price returns inside a recent price range, this indicates a willingness on the part of the market makers to reprice to levels not efficiently traded for fair value.  When we are thinking retracement, the go to is for ICT tools we are looking for liquidity gaps and liquidity voids. When we look for price when we see run ups real quick and run downs in price in other words real quick rallies up or real quick rallies down in price many times that range that’s created will want to come back in and close that in. Find an example below: </w:t></w:r></w:p><w:p w14:paraId="190FA0C4" w14:textId="77777777" w:rsidR="00780048" w:rsidRDefault="00780048" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="50E73335" w14:textId="42A44D3C" w:rsidR="00780048" w:rsidRDefault="00331D6B" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="00331D6B"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="3433CEEA" wp14:editId="6F25CD0E"><wp:extent cx="5731510" cy="3221355"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="1307047423" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="1307047423" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId7"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5731510" cy="3221355"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="72F08C21" w14:textId="77777777" w:rsidR="00660B99" w:rsidRDefault="00660B99" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="633AF0EE" w14:textId="1F0E603F" w:rsidR="00660B99" w:rsidRDefault="00660B99" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>This is an example of a retracement</w:t></w:r><w:r w:rsidR="00780048"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>. As you can see here the orange shaded area we have a real quick sudden movement away from a price level and that quick sudden movement creates what we call as a liquidity void. What we’ll do is we’ll wait as a trader, we wont chase price, we will  wait and say okay there’s going to be either an indication that get long and try to fill in that range or we can wa</w:t></w:r><w:r w:rsidR="00963F5E"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>it</w:t></w:r><w:r w:rsidR="00780048"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> for the come all the way back to it and fill in the liquidity void. Once it hits it then it will probably resume going lower and that’s what we’re looking for in terms of liquidity void. </w:t></w:r></w:p><w:p w14:paraId="77311253" w14:textId="77777777" w:rsidR="00660B99" w:rsidRDefault="00660B99" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="7667B6A2" w14:textId="77777777" w:rsidR="00660B99" w:rsidRPr="0068293F" w:rsidRDefault="00660B99" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="55322873" w14:textId="77777777" w:rsidR="009F50F4" w:rsidRPr="009F50F4" w:rsidRDefault="009F50F4" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr></w:pPr></w:p><w:p w14:paraId="21C749D4" w14:textId="556BEA4C" w:rsidR="009F50F4" w:rsidRDefault="00237762" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr></w:pPr><w:r w:rsidRPr="00237762"><w:rPr><w:sz w:val="40"/><w:szCs w:val="40"/></w:rPr><w:t xml:space="preserve">What is Reversal? </w:t></w:r></w:p><w:p w14:paraId="60B60218" w14:textId="35883AD4" w:rsidR="00237762" w:rsidRDefault="00237762" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Reversal is when price moves the opposite direction the current direction has taken in.</w:t></w:r><w:r w:rsidR="0022616A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> So if we are looking for reversals, we are directly coupling that with an ICT tool of liquidity pools. </w:t></w:r></w:p><w:p w14:paraId="7AC111AD" w14:textId="453EEE49" w:rsidR="0022616A" w:rsidRDefault="0022616A" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">The Importance of Reversal: When the price reverses direction, it indicates the market makers have ran level of stops and a significant move should unfold in the new direction. </w:t></w:r></w:p><w:p w14:paraId="60B47CC6" w14:textId="33BEFE45" w:rsidR="0022616A" w:rsidRDefault="0022616A" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:t>What to look for in price: The liquidity pools just above an old price high and just below an old price low</w:t></w:r></w:p><w:p w14:paraId="07FB16AC" w14:textId="77777777" w:rsidR="0022616A" w:rsidRDefault="0022616A" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="3CEB39E0" w14:textId="51DE821E" w:rsidR="0022616A" w:rsidRDefault="0022616A" w:rsidP="00265F44"><w:pPr><w:tabs><w:tab w:val="left" w:pos="958"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="0022616A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="60328C97" wp14:editId="18A52BBA"><wp:extent cx="5731510" cy="3206115"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="1222726858" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="1222726858" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId8"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5731510" cy="3206115"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="4E686509" w14:textId="77777777" w:rsidR="0040359A" w:rsidRDefault="0022616A" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">The screenshot above shows examples of </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>reversals,every</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> ‘x’ indicates where stops would be and </w:t></w:r><w:r w:rsidR="0040359A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>the market goes just above those levels and rejects and goes the other way or goes just below those levels where there’s and ‘x’ and rejects and goes the other way. Look how many times there’s so many opportunities just on this one chart.</w:t></w:r></w:p><w:p w14:paraId="09D50685" w14:textId="77777777" w:rsidR="0040359A" w:rsidRDefault="0040359A" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="235032C2" w14:textId="77777777" w:rsidR="0040359A" w:rsidRPr="00C53BB4" w:rsidRDefault="0040359A" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="44"/><w:szCs w:val="44"/></w:rPr></w:pPr><w:r w:rsidRPr="00C53BB4"><w:rPr><w:sz w:val="44"/><w:szCs w:val="44"/></w:rPr><w:t>What is Consolidation?</w:t></w:r></w:p><w:p w14:paraId="5BB671E8" w14:textId="573A68E8" w:rsidR="0022616A" w:rsidRDefault="0040359A" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">  </w:t></w:r><w:r w:rsidR="00C53BB4"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Consolidation is when price moves inside a clear trading range and shows no willingness to move significantly higher or lower. </w:t></w:r></w:p><w:p w14:paraId="3FD76C0C" w14:textId="6D85D19C" w:rsidR="00C53BB4" w:rsidRDefault="00C53BB4" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">The Importance of Consolidation: When price consolidates, it indicates the market makers are allowing orders to build on both sides of the market. Expect a new Expansion near term. </w:t></w:r></w:p><w:p w14:paraId="13AD7706" w14:textId="5BBC1BE8" w:rsidR="00C53BB4" w:rsidRDefault="00C53BB4" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>What we look for in price: We are waiting for the impulse move or impu</w:t></w:r><w:r w:rsidR="0081417A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>l</w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">se swing in price away from the equilibrium price level that is found exactly in the halfway point of the consolidation range. </w:t></w:r></w:p><w:p w14:paraId="66A86A87" w14:textId="77777777" w:rsidR="00C53BB4" w:rsidRDefault="00C53BB4" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr></w:p><w:p w14:paraId="68852CCB" w14:textId="3ECB5CEA" w:rsidR="00C53BB4" w:rsidRDefault="00664B41" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="1F91A1B9" w14:textId="74B23C77" w:rsidR="00C53BB4" w:rsidRDefault="00664B41" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="00664B41"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="74C6A494" wp14:editId="2AF30E69"><wp:extent cx="5731510" cy="3259455"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="645849587" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="645849587" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId9"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5731510" cy="3259455"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="0A33D221" w14:textId="1C3224BE" w:rsidR="00F06CA8" w:rsidRPr="0022616A" w:rsidRDefault="00C53BB4" w:rsidP="0022616A"><w:pPr><w:tabs><w:tab w:val="left" w:pos="1125"/></w:tabs><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">We see here where we’ve identified a range defined specifically by the bodies of the candles not the wicks as you can see, price moves out </w:t></w:r><w:r w:rsidR="0093533C"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>in an expansive manner and then comes back</w:t></w:r><w:r w:rsidR="00664B41"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> to the equilibrium price point and then to the </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="00664B41"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>upside.By</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidR="00664B41"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> having an understanding of these specific characteristics and elements of trading a setup you’ll give yourself framework to first learn how to practice and study price action and eventually work towards understanding </w:t></w:r><w:r w:rsidR="0081417A"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>consistent</w:t></w:r><w:r w:rsidR="00664B41"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> setup discovery. </w:t></w:r></w:p><w:sectPr w:rsidR="00F06CA8" w:rsidRPr="0022616A"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>